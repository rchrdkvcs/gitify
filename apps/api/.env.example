TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=change_this_app_key
NODE_ENV=development
FRONTEND_URL=http://localhost:3333

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=app
SESSION_DRIVER=cookie

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3333/auth/github/callback

# Dev only — exposes a non-HttpOnly cookie + GET /auth/dev returns the token as JSON
# Lets you copy the token into Bruno/Postman to test protected routes
# Never set this in production
ENABLE_DEV_TOKEN=true

# Server-side GitHub PAT (no special scopes needed, public repos only)
# Required for showcase seeder and lazy showcase fetching
GITHUB_SERVER_TOKEN=

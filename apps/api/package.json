{
  "name": "@gitify/api",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#services/*": "./app/services/*.js",
    "#models/*": "./app/models/*.js",
    "#middlewares/*": "./app/middlewares/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#validators/*": "./app/validators/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#providers/*": "./providers/*.js"
  },
  "exports": {
    "./registry": "./.adonisjs/client/registry/index.ts",
    "./data": "./.adonisjs/client/data.d.ts"
  },
  "scripts": {
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "start": "node bin/server.js",
    "test": "node ace test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@adonisjs/ally": "^6.3.0",
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/core": "^7.3.2",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/session": "^8.1.0",
    "@tuyau/core": "^1.2.2",
    "@vinejs/vine": "^4.4.0",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "ulid": "^3.0.1"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.1.0",
    "@japa/assert": "^4.1.1",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.2",
    "typescript": "~6.0.3",
    "youch": "^4.1.1"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  }
}

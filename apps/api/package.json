{
  "name": "@gitify/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint ",
    "format": "prettier --write ",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#services/*": "./app/services/*.js",
    "#models/*": "./app/models/*.js",
    "#middlewares/*": "./app/middlewares/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#validators/*": "./app/validators/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#transformers/*": "./app/transformers/*.js"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/core": "^7.1.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/lucid": "^22.2.0",
    "@adonisjs/session": "^8.0.0",
    "@vinejs/vine": "^4.3.0",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "ulid": "^3.0.1"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.2.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.1.0",
    "@japa/assert": "^4.1.1",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.6.2",
    "typescript": "~6.0.2",
    "youch": "^4.1.0"
  },
  "prettier": "@adonisjs/prettier-config",
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  }
}
